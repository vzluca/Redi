{
  "name": "Redi — Cerebro (Multicanal + Cotización)",
  "nodes": [
    {
      "parameters": {
        "content": "## 🧠 REDI — CEREBRO\nAsistente de RedLabs. Atiende WhatsApp, Instagram y Email.\nTranscribe audios (Whisper), cotiza desde el Sheet, agenda llamadas,\nguarda leads y deriva a Luca cuando hace falta.\n\n**Antes de activar:** cargá credenciales en cada nodo y pegá el System\nPrompt de `brain/redi-system-prompt.md` en el nodo 'Redi (AI Agent)'.",
        "height": 260,
        "width": 420,
        "color": 4
      },
      "id": "note-header",
      "name": "Nota — Cómo usar",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [-460, -320]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "redi-whatsapp",
        "options": {}
      },
      "id": "wh-wpp",
      "name": "WhatsApp In (360dialog)",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [-440, -40],
      "webhookId": "redi-whatsapp"
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "redi-instagram",
        "options": {}
      },
      "id": "wh-ig",
      "name": "Instagram In (Meta)",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [-440, 160],
      "webhookId": "redi-instagram"
    },
    {
      "parameters": {
        "pollTimes": { "item": [ { "mode": "everyMinute" } ] },
        "simple": false,
        "filters": {},
        "options": {}
      },
      "id": "tr-gmail",
      "name": "Email In (Gmail)",
      "type": "n8n-nodes-base.gmailTrigger",
      "typeVersion": 1,
      "position": [-440, 360]
    },
    {
      "parameters": {
        "jsCode": "// Normaliza el payload de 360dialog a un formato común para Redi\nconst body = $json.body || $json;\nconst msg = body?.messages?.[0] || {};\nconst contact = body?.contacts?.[0] || {};\nlet type = 'text';\nlet text = msg?.text?.body || '';\nlet mediaId = '';\nif (msg.type === 'audio' || msg.voice) { type = 'audio'; mediaId = msg?.audio?.id || msg?.voice?.id || ''; }\nelse if (msg.type === 'image') { type = 'image'; mediaId = msg?.image?.id || ''; text = msg?.image?.caption || ''; }\nreturn [{ json: {\n  channel: 'whatsapp',\n  from: msg.from || contact?.wa_id || '',\n  name: contact?.profile?.name || 'Cliente',\n  type,\n  text,\n  mediaId,\n  sessionId: 'wpp_' + (msg.from || contact?.wa_id || 'anon')\n}}];"
      },
      "id": "norm-wpp",
      "name": "Normalizar WhatsApp",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-200, -40]
    },
    {
      "parameters": {
        "jsCode": "// Normaliza el payload de Instagram Messaging (Meta) a formato común\nconst entry = ($json.body?.entry || $json.entry || [])[0] || {};\nconst messaging = (entry.messaging || [])[0] || {};\nconst senderId = messaging?.sender?.id || '';\nconst text = messaging?.message?.text || '';\nconst att = messaging?.message?.attachments?.[0];\nlet type = 'text'; let mediaUrl = '';\nif (att?.type === 'audio') { type = 'audio'; mediaUrl = att?.payload?.url || ''; }\nelse if (att?.type === 'image') { type = 'image'; mediaUrl = att?.payload?.url || ''; }\nreturn [{ json: {\n  channel: 'instagram',\n  from: senderId,\n  name: 'Seguidor IG',\n  type,\n  text,\n  mediaUrl,\n  sessionId: 'ig_' + senderId\n}}];"
      },
      "id": "norm-ig",
      "name": "Normalizar Instagram",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-200, 160]
    },
    {
      "parameters": {
        "jsCode": "// Normaliza un email de Gmail a formato común\nconst from = $json.from?.value?.[0]?.address || $json.from || '';\nconst name = $json.from?.value?.[0]?.name || 'Contacto';\nconst text = ($json.subject ? 'Asunto: ' + $json.subject + '\\n\\n' : '') + ($json.textPlain || $json.snippet || '');\nreturn [{ json: {\n  channel: 'email',\n  from,\n  name,\n  type: 'text',\n  text,\n  threadId: $json.threadId || '',\n  sessionId: 'mail_' + from\n}}];"
      },
      "id": "norm-mail",
      "name": "Normalizar Email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-200, 360]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose" },
          "conditions": [
            { "id": "c1", "leftValue": "={{ $json.type }}", "rightValue": "audio", "operator": { "type": "string", "operation": "equals" } }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "if-audio",
