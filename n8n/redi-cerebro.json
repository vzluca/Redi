    {
      "parameters": {
        "name": "Calcular_Entrega",
        "description": "Estima el tiempo de entrega en días hábiles. Pasá un JSON string: {\"dias_base\": N, \"en_curso\": M}. 'dias_base' sale de config_operativa.tiempos_entrega del catálogo; 'en_curso' es la cantidad de proyectos que Luca ya tiene en curso (usar Ver_Proyectos_En_Curso). Devuelve un rango tipo 'X a Y días hábiles'.",
        "jsCode": "// Modelo 'reparto parejo': con K proyectos a la vez, cada uno tarda dias_base*K.\n// Capacidad 2 en paralelo; si está llena, el nuevo espera en cola. Ajustar con Luca.\nlet p; try { p = JSON.parse(query); } catch (e) { p = {}; }\nconst diasBase = Number(p.dias_base) || 5;\nconst enCurso = Number(p.en_curso) || 0;\nconst capacidad = 2;   // proyectos en paralelo\nconst buffer = 2;      // holgura en días\nconst rangoPct = 0.2;  // ancho del rango\nlet dias;\nif (enCurso < capacidad) {\n  const simultaneos = Math.min(enCurso + 1, capacidad);\n  dias = diasBase * simultaneos;\n} else {\n  const esperaCola = diasBase; // ~una tanda para que se libere un lugar\n  dias = esperaCola + diasBase * capacidad;\n}\ndias += buffer;\nconst min = dias;\nconst max = Math.ceil(dias * (1 + rangoPct));\nreturn `${min} a ${max} días hábiles`;"
      },
      "id": "tool-entrega",
      "name": "Calcular_Entrega",
      "type": "@n8n/n8n-nodes-langchain.toolCode",
      "typeVersion": 1.1,
      "position": [1320, 360]
    },
