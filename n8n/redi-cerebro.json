    {
      "parameters": {
        "descriptionType": "manual",
        "toolDescription": "Devuelve los proyectos que Luca tiene 'En curso' en la hoja 'Clientes Activos'. Usar para contar cuántos hay en curso y estimar el tiempo de entrega.",
        "operation": "getAll",
