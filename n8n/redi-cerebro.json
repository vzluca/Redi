    {
      "parameters": { "mode": "combine", "combineBy": "combineAll", "options": {} },
      "id": "merge-in",
      "name": "Unificar entrada",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [540, 120]
    },
    {
      "parameters": {
        "jsCode": "// BUFFER anti-mensajes-cortos: guarda el mensaje y marca su timestamp.\n// Después del Wait, solo el ÚLTIMO mensaje del contacto sigue; ese junta todo.\nconst store = $getWorkflowStaticData('global');\nstore.buffers = store.buffers || {};\nconst key = $json.sessionId;\nconst now = Date.now();\nconst buf = store.buffers[key] || { msgs: [], lastTs: 0 };\nif ($json.text && $json.text.trim()) buf.msgs.push($json.text.trim());\nbuf.lastTs = now;\nstore.buffers[key] = buf;\nreturn [{ json: { ...$json, _myTs: now } }];"
      },
      "id": "buffer",
      "name": "Bufferizar",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [740, 120]
    },
    {
      "parameters": { "amount": 8, "unit": "seconds" },
      "id": "wait",
      "name": "Esperar 8s",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [900, 120],
      "webhookId": "redi-wait"
    },
    {
      "parameters": {
        "jsCode": "// ¿Soy el último mensaje del contacto? Si llegó otro después, este se descarta\n// (el más nuevo procesará todo). Si soy el último, junto todos los mensajes en uno.\nconst store = $getWorkflowStaticData('global');\nstore.buffers = store.buffers || {};\nconst key = $json.sessionId;\nconst buf = store.buffers[key];\nif (!buf || buf.lastTs !== $json._myTs) { return []; }\nconst fullText = buf.msgs.join('\\n');\ndelete store.buffers[key];\nreturn [{ json: { ...$json, text: fullText } }];"
      },
      "id": "islast",
      "name": "¿Último mensaje?",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1060, 120]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.text }}",
        "options": {
          "systemMessage": "PEGAR ACÁ el contenido completo de brain/redi-system-prompt.md. (Redi: si ya habló antes con el contacto, saluda 'hola de nuevo' sin re-presentarse. Descubre qué necesita con preguntas, recomienda lo mínimo, cotiza desde el Sheet con desglose y tiempo de entrega -aclarando que cuenta desde que el cliente manda el material-, ofrece llamada y recién si la rechazan pasa la seña 50%. Carga y actualiza el CRM. Nunca dice 'nodos'. Conciso, sin tools de más.)",
          "maxIterations": 6
        }
      },
