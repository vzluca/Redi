    {
      "parameters": {
        "toolDescription": "Deriva la conversación a Luca (humano). Usar cuando el cliente pide hablar con una persona, se frustra, o el proyecto es Complejo+. Enviar motivo y resumen.",
        "method": "POST",
        "url": "https://waba-v2.360dialog.io/messages",
        "sendHeaders": true,
        "headerParameters": { "parameters": [ { "name": "D360-API-KEY", "value": "PEGAR_API_KEY_360_DE_LUCA" } ] },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"messaging_product\": \"whatsapp\",\n  \"to\": \"NUMERO_DE_LUCA\",\n  \"type\": \"text\",\n  \"text\": { \"body\": \"🔔 Redi te deriva un caso.\\nMotivo: {{ $fromAI('motivo') }}\\nResumen: {{ $fromAI('resumen') }}\" }\n}",
        "options": {}
      },
